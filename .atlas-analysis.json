  "keyFeatures": [
    "OCI Distribution Specification compliance",
    "Multiple storage backends (local filesystem, S3, GCS)",
    "Authentication via htpasswd, LDAP, OpenID Connect, mTLS",
    "Role-based access control (RBAC)",
    "Registry sync/mirroring across registries",
    "GraphQL-powered image search and CVE scanning",
    "Image trust via Cosign and Notation",
    "Scale-out clustering with Redis",
    "Prometheus metrics and UI",
    "Built-in image scrubbing and garbage collection",
    "CLI client (zli) for managing the registry"
  ],
  "publicApiSurface": [
    "GET /v2/ — API version check",
    "GET /v2/<name>/tags/list — List image tags",
    "GET /v2/<name>/manifests/<reference> — Get manifest",
    "PUT /v2/<name>/manifests/<reference> — Push manifest",
    "DELETE /v2/<name>/manifests/<reference> — Delete manifest",
    "GET /v2/<name>/blobs/<digest> — Get blob",
    "POST /v2/<name>/blobs/uploads/ — Initiate blob upload",
    "PUT /v2/<name>/blobs/uploads/<uuid> — Complete blob upload",
    "DELETE /v2/<name>/blobs/<digest> — Delete blob",
    "GET /v2/_catalog — List repositories",
    "POST /v2/_zot/ext/search (GraphQL) — Search images and CVEs",
    "GET /metrics — Prometheus metrics endpoint",
    "GET /livez, /readyz, /startupz — Health check endpoints"
  ]
}
